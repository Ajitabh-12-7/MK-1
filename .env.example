# MARS — Environment Variables Template
# Copy this file to .env and fill in your API keys
# NEVER commit .env to git

# ── Groq (LLM — free tier) ───────────────────────────────────────────────────
# Get your key at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# ── Tavily (web search — free tier) ──────────────────────────────────────────
# Get your key at: https://app.tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# ── LangSmith (observability — free tier) ─────────────────────────────────────
# Get your key at: https://smith.langchain.com/
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=MARS-MultiAgent-Research
